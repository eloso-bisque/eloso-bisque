# URL of the kissinger-api GraphQL endpoint.
# On Railway, deploy kissinger-api as a separate service and reference it here
# using a Railway private network URL or public URL.
#
# Example (Railway private networking):
#   KISSINGER_API_URL=http://kissinger-api.railway.internal:8080/graphql
#
# Example (public URL with token auth):
#   KISSINGER_API_URL=https://kissinger-api.up.railway.app/graphql
#
# Never expose this variable with NEXT_PUBLIC_ — it is server-side only.
KISSINGER_API_URL=http://localhost:8080/graphql

# Bearer token required if kissinger-api was started with KISSINGER_API_TOKEN set.
# Leave blank for unauthenticated access (local dev).
KISSINGER_API_TOKEN=

# Optional: enable simple HTTP Basic Auth on the bisque frontend itself,
# so only authorised users can browse the CRM UI.
# BISQUE_BASIC_USER=admin
# BISQUE_BASIC_PASS=changeme
